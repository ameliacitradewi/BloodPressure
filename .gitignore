# ------------------------------------------------------------
DerivedData/
build/
Build/
Products/
.build/
.xcodebuild/
SourcePackages/

*.xcarchive
*.ipa
*.dSYM
*.dSYM.zip
*.resultbundle
*.xccovarchive
*.xccovreport

# ------------------------------------------------------------
# Xcode user-specific data
#
# Do not ignore:
# - *.xcodeproj/project.pbxproj
# - *.xcworkspace/contents.xcworkspacedata
# - shared schemes
# ------------------------------------------------------------
xcuserdata/
*.xcuserstate
*.xcscmblueprint
*.xccheckout
*.moved-aside
*.hmap

*.xcodeproj/xcuserdata/
*.xcodeproj/project.xcworkspace/xcuserdata/
*.xcworkspace/xcuserdata/

# Old Xcode per-user files
*.mode1v3
*.mode2v3
*.perspectivev3
!default.mode1v3
!default.mode2v3
!default.perspectivev3

# ------------------------------------------------------------
# Swift Package Manager
#
# Package.resolved is intentionally NOT ignored. Commit it so
# every developer resolves the same dependency versions.
# ------------------------------------------------------------
.swiftpm/
Packages/
Package.pins

!Package.swift
!Package.resolved
!*.xcodeproj/project.pbxproj
!*.xcodeproj/xcshareddata/xcschemes/*.xcscheme
!*.xcworkspace/contents.xcworkspacedata
!*.xcworkspace/xcshareddata/xcschemes/*.xcscheme

# ------------------------------------------------------------
# FastVLM external repository
#
# The official FastVLM repository is cloned locally into Vendor.
# Recreate it by following README.md instead of committing the
# complete third-party repository.
# ------------------------------------------------------------
Vendor/ml-fastvlm/

# ------------------------------------------------------------
# FastVLM model weights and generated model files
#
# The model is large and must be downloaded separately.
# Configuration/tokenizer files inside the downloaded model
# folder are also recreated by the download script.
# ------------------------------------------------------------
**/FastVLM/model/
**/fastvlm_*/model/
checkpoints/
models/downloaded/
DownloadedModels/

*.safetensors
*.gguf
*.npz
*.bin
*.pth
*.pt
*.ckpt
*.onnx
*.mlmodelc/

# Keep source Core ML packages only when intentionally needed.
# Uncomment the following lines if large Core ML source models
# are added locally and should not be committed.
# *.mlpackage/
# *.mlmodel

# ------------------------------------------------------------
# Hugging Face / ML caches
# ------------------------------------------------------------
.cache/
huggingface/
.huggingface/
hf_cache/

